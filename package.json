{
  "name": "scolive-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "NODE_ENV=development EXPO_NO_DEVTOOLS=1 EXPO_USE_FAST_RESOLVER=1 EXPO_NO_METRO_WORKSPACE_ROOT=1 npx expo start --scheme scolive --localhost --max-workers 4",
    "start:clean": "NODE_ENV=development EXPO_NO_DEVTOOLS=1 EXPO_USE_FAST_RESOLVER=1 EXPO_NO_METRO_WORKSPACE_ROOT=1 npx expo start --clear --scheme scolive --localhost --max-workers 4",
    "android": "bash scripts/android-dev-build.sh",
    "android:build": "bash scripts/android-dev-build.sh",
    "android:build:full": "NODE_ENV=development npx expo run:android",
    "android:build:precommit": "bash scripts/android-precommit-build.sh",
    "android:emulator": "bash scripts/android-emulator-nvidia.sh Scolive_Dev_AOSP_API33_Fresh",
    "android:reinstall": "export NODE_ENV=development && ~/Android/Sdk/platform-tools/adb uninstall com.zoutigo.scoliveapp || true && bash scripts/android-dev-build.sh",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --runInBand --watchman=false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check:repo": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "check:precommit": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run android:build:precommit",
    "prepare": "sh scripts/setup-git-hooks.sh",
    "android:build:release": "bash scripts/android-release-build.sh",
    "e2e:build": "npm run android:build:release",
    "e2e:test:smoke": "bash scripts/maestro-run-flow.sh smoke",
    "e2e:test:auth-email": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh auth-email",
    "e2e:test:auth-phone": "PHONE_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh auth-phone",
    "e2e:test:onboarding-email": "EMAIL_LOGIN_SCENARIO=password_change_required ONBOARDING_SCENARIO=email_parent_happy bash scripts/maestro-run-flow.sh onboarding-email",
    "e2e:test:onboarding-phone": "PHONE_LOGIN_SCENARIO=profile_setup_required ONBOARDING_SCENARIO=phone_happy bash scripts/maestro-run-flow.sh onboarding-phone",
    "e2e:test:recovery-password": "PASSWORD_SCENARIO=happy_path bash scripts/maestro-run-flow.sh recovery-password",
    "e2e:test:recovery-pin": "PIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh recovery-pin",
    "e2e:test": "npm run e2e:test:smoke && npm run e2e:test:auth-email && npm run e2e:test:auth-phone && npm run e2e:test:onboarding-email && npm run e2e:test:onboarding-phone && npm run e2e:test:recovery-password && npm run e2e:test:recovery-pin",
    "e2e": "npm run e2e:build && npm run e2e:test",
    "maestro:install": "bash scripts/install-maestro.sh"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^expo/src/winter/ImportMetaRegistry$": "<rootDir>/__mocks__/expoImportMetaRegistry.js",
      "^(.*)/app/\\(home\\)/(.*)$": "<rootDir>/app/(home)/$2"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~55.0.8",
    "expo-apple-authentication": "^55.0.9",
    "expo-auth-session": "^55.0.9",
    "expo-document-picker": "~55.0.11",
    "expo-image-picker": "~55.0.16",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-secure-store": "^55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.10",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-pell-rich-editor": "^1.10.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.12",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1"
  },
  "private": true
}
