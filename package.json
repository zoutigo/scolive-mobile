{
  "name": "scolive-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "NODE_ENV=development EXPO_NO_DEVTOOLS=1 EXPO_USE_FAST_RESOLVER=1 EXPO_NO_METRO_WORKSPACE_ROOT=1 npx expo start --scheme scolive --localhost --max-workers 4",
    "start:clean": "NODE_ENV=development EXPO_NO_DEVTOOLS=1 EXPO_USE_FAST_RESOLVER=1 EXPO_NO_METRO_WORKSPACE_ROOT=1 npx expo start --clear --scheme scolive --localhost --max-workers 4",
    "android": "bash scripts/android-dev-build.sh",
    "android:build": "bash scripts/android-dev-build.sh",
    "android:build:e2e:mock": "bash scripts/android-e2e-mock-build.sh",
    "android:open": "ADB_BIN=\"${ADB_BIN:-$HOME/Android/Sdk/platform-tools/adb}\"; SERIAL=$($ADB_BIN devices 2>/dev/null | awk '/^emulator-/{print $1; exit}'); if [ -z \"$SERIAL\" ]; then echo 'Aucun émulateur Android détecté.' >&2; exit 1; fi; $ADB_BIN -s \"$SERIAL\" shell am start -W -n com.zoutigo.scoliveapp/.MainActivity",
    "android:build:full": "NODE_ENV=development npx expo run:android",
    "android:build:precommit": "bash scripts/android-precommit-build.sh",
    "android:emulator": "bash scripts/android-emulator-nvidia.sh Scolive_Dev_AOSP_API33",
    "android:emulator:google": "bash scripts/android-emulator-nvidia.sh Scolive_E2E_GooglePlay_API33",
    "android:emulator:e2e:google": "bash scripts/android-emulator-nvidia.sh Scolive_E2E_GooglePlay_API33",
    "android:reinstall": "export NODE_ENV=development && ~/Android/Sdk/platform-tools/adb uninstall com.zoutigo.scoliveapp || true && bash scripts/android-dev-build.sh",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --runInBand --watchman=false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check:repo": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "check:precommit": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run android:build:precommit",
    "prepare": "sh scripts/setup-git-hooks.sh",
    "android:build:release": "bash scripts/android-release-build.sh",
    "android:build:release:google": "bash scripts/android-e2e-google-build.sh",
    "e2e:build": "npm run android:build:release",
    "e2e:build:google": "npm run android:build:release:google",
    "e2e:test:smoke": "bash scripts/maestro-run-flow.sh smoke",
    "e2e:test:auth-email": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh auth-email",
    "e2e:test:auth-phone": "PHONE_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh auth-phone",
    "e2e:test:auth-google": "bash scripts/maestro-run-flow.sh auth-google",
    "e2e:test:auth-google:full": "bash scripts/maestro-run-flow.sh auth-google-full",
    "e2e:google:full": "npm run e2e:build:google && npm run e2e:test:auth-google:full",
    "e2e:test:onboarding-email": "EMAIL_LOGIN_SCENARIO=password_change_required ONBOARDING_SCENARIO=email_parent_happy bash scripts/maestro-run-flow.sh onboarding-email",
    "e2e:test:onboarding-phone": "PHONE_LOGIN_SCENARIO=profile_setup_required ONBOARDING_SCENARIO=phone_happy bash scripts/maestro-run-flow.sh onboarding-phone",
    "e2e:test:feed": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh feed",
    "e2e:test:feed:interactions": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh feed-interactions",
    "e2e:test:feed:child-class": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh feed-child-class",
    "e2e:test:feed:child-class:errors": "EMAIL_LOGIN_SCENARIO=happy_path FEED_SCENARIO=action_errors bash scripts/maestro-run-flow.sh feed-child-class-errors",
    "e2e:test:feed:child-class:load-error": "EMAIL_LOGIN_SCENARIO=happy_path FEED_SCENARIO=list_error bash scripts/maestro-run-flow.sh feed-child-class-load-error",
    "e2e:test:timetable:parent": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh timetable-parent",
    "e2e:test:timetable:crud": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh timetable-crud",
    "e2e:test:timetable:error": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh timetable-error",
    "e2e:test:notes:parent": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh notes-parent",
    "e2e:test:notes:crud": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh notes-crud-teacher",
    "e2e:test:messaging": "EMAIL_LOGIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh messaging-compose",
    "e2e:test:discipline": "EMAIL_LOGIN_SCENARIO=happy_path DISCIPLINE_SCENARIO=happy_path bash scripts/maestro-run-flow.sh discipline",
    "e2e:test:discipline:error": "EMAIL_LOGIN_SCENARIO=happy_path DISCIPLINE_SCENARIO=list_error_once bash scripts/maestro-run-flow.sh discipline-error",
    "e2e:test:discipline:crud:absence": "EMAIL_LOGIN_SCENARIO=discipline_admin DISCIPLINE_SCENARIO=happy_path bash scripts/maestro-run-flow.sh discipline-crud-absence",
    "e2e:test:discipline:crud:retard": "EMAIL_LOGIN_SCENARIO=discipline_admin DISCIPLINE_SCENARIO=happy_path bash scripts/maestro-run-flow.sh discipline-crud-retard",
    "e2e:test:discipline:crud:sanction": "EMAIL_LOGIN_SCENARIO=discipline_admin DISCIPLINE_SCENARIO=happy_path bash scripts/maestro-run-flow.sh discipline-crud-sanction",
    "e2e:test:discipline:crud": "npm run e2e:test:discipline:crud:absence && npm run e2e:test:discipline:crud:retard && npm run e2e:test:discipline:crud:sanction",
    "e2e:test:recovery-password": "PASSWORD_SCENARIO=happy_path bash scripts/maestro-run-flow.sh recovery-password",
    "e2e:test:recovery-pin": "PIN_SCENARIO=happy_path bash scripts/maestro-run-flow.sh recovery-pin",
    "e2e:test:account:add-email": "EMAIL_LOGIN_SCENARIO=happy_path ACCOUNT_SCENARIO=phone_only_user bash scripts/maestro-run-flow.sh account-add-email",
    "e2e:test:account:create-password": "EMAIL_LOGIN_SCENARIO=happy_path ACCOUNT_SCENARIO=phone_only_user bash scripts/maestro-run-flow.sh account-create-password",
    "e2e:test:account:add-phone": "EMAIL_LOGIN_SCENARIO=happy_path ACCOUNT_SCENARIO=email_only_user bash scripts/maestro-run-flow.sh account-add-phone",
    "e2e:test:account": "npm run e2e:test:account:add-email && npm run e2e:test:account:create-password && npm run e2e:test:account:add-phone",
    "e2e:test": "npm run e2e:test:smoke && npm run e2e:test:auth-email && npm run e2e:test:auth-phone && npm run e2e:test:auth-google && npm run e2e:test:onboarding-email && npm run e2e:test:onboarding-phone && npm run e2e:test:feed && npm run e2e:test:feed:interactions && npm run e2e:test:messaging && npm run e2e:test:discipline && npm run e2e:test:discipline:error && npm run e2e:test:discipline:crud && npm run e2e:test:recovery-password && npm run e2e:test:recovery-pin && npm run e2e:test:account",
    "e2e": "npm run e2e:build && npm run e2e:test",
    "maestro:install": "bash scripts/install-maestro.sh"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^expo/src/winter/ImportMetaRegistry$": "<rootDir>/__mocks__/expoImportMetaRegistry.js",
      "^(.*)/app/\\(home\\)/(.*)$": "<rootDir>/app/(home)/$2"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~55.0.8",
    "expo-apple-authentication": "^55.0.9",
    "expo-auth-session": "^55.0.9",
    "expo-document-picker": "~55.0.11",
    "expo-image-picker": "~55.0.16",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-secure-store": "^55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.10",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-pell-rich-editor": "^1.10.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.12",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1"
  },
  "private": true
}
