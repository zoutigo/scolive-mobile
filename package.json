{
  "name": "scolive-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_NO_DEVTOOLS=1 npx expo start --dev-client",
    "start:clean": "EXPO_NO_DEVTOOLS=1 npx expo start --dev-client --clear",
    "android": "npx expo run:android",
    "android:build": "npx expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check:repo": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "prepare": "sh scripts/setup-git-hooks.sh"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^expo/src/winter/ImportMetaRegistry$": "<rootDir>/__mocks__/expoImportMetaRegistry.js",
      "^(.*)/app/\\(home\\)/(.*)$": "<rootDir>/app/(home)/$2"
    }
  },
  "dependencies": {
    "expo": "~55.0.8",
    "expo-apple-authentication": "^55.0.9",
    "expo-auth-session": "^55.0.9",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-secure-store": "^55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.10",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.12",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1"
  },
  "private": true
}
